# ── LLM 主模型 ──
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ── 评估模型（可选，用于 Evaluator / Reflector 交叉检查，不配则用主模型）──
EVAL_API_KEY=sk-xxx
EVAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_MODEL_NAME=qwen-plus

# ── Embedding ──
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# ── Milvus ──
MILVUS_URI=http://localhost:19530

# ── MySQL（Phase 7 启用）──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mindsearch
MYSQL_PASSWORD=mindsearch_pass
MYSQL_DATABASE=mindsearch

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── FastAPI ──
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
